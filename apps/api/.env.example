# Kuwboo API — Local Development Environment
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000

# Logging (Pino)
# Levels: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kuwboo
DB_USER=kuwboo_admin
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRY=7d

# Twilio (phone OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Transactional email (AWS SES v2 today; future: Postmark / Resend)
# In production SES creds come from AWS Secrets Manager (/kuwboo/smtp) via
# aws-secrets bootstrap. Leave blank locally and the SDK will fall through
# to the default credential chain — EmailService will simply no-op any
# delivery attempts that fail.
EMAIL_PROVIDER_NAME=ses
EMAIL_DEFAULT_FROM=hello@kuwboo.com
SES_REGION=eu-west-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# When set to 1/true/yes AND NODE_ENV != production, sendEmailOtp and
# sendPasswordResetOtp echo the plaintext code back in the response so
# the mobile client can render it in its on-screen OTP banner without
# waiting on real email delivery. Always off in production.
ENABLE_DEV_OTP_ECHO=

# Firebase (push notifications)
# On EC2 prod these come from AWS Secrets Manager (/kuwboo/firebase) when
# AWS_LOAD_SECRETS=1. See apps/api/src/bootstrap/aws-secrets.ts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AWS Secrets Manager bootstrap
# Set to "1" in environments where the process can assume an IAM role that
# permits secretsmanager:GetSecretValue on arn:aws:secretsmanager:eu-west-2:
# *:secret:/kuwboo/*. On EC2 (prod) this should be 1. In local dev leave
# empty and populate FIREBASE_* manually in .env.
AWS_LOAD_SECRETS=
AWS_REGION=eu-west-2

# Apple Sign In
# APPLE_BUNDLE_ID is the iOS App ID (e.g. com.kuwboo.app). Every Apple
# identity token and Server-to-Server notification MUST have aud equal
# to APPLE_BUNDLE_ID (or APPLE_SERVICE_ID when set).
# Required in production; AppleJwksService will fail closed if empty.
APPLE_BUNDLE_ID=com.kuwboo.app
# APPLE_SERVICE_ID is optional — set it to enable "Sign in with Apple"
# on the web (future kuwboo.com button). Leave blank for mobile-only.
APPLE_SERVICE_ID=
# Reserved for the future /auth/apple/token and /auth/apple/revoke
# endpoints which need a client secret signed with the .p8 private key.
# Not consumed by PR 2; provisioned together so the secret bundle is
# validated in one place.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# AWS (media storage)
AWS_REGION=eu-west-2
AWS_S3_BUCKET=kuwboo-media-dev
AWS_CLOUDFRONT_DOMAIN=

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# Profile-completeness nudges (D3a)
# When 1/true/yes, the nightly cron enumerates users whose
# profile_completeness_pct < 70 and enqueues one FCM nudge per eligible
# user (respecting the 7-day per-user cooldown). Leave at 0 in dev /
# staging to avoid spamming test devices.
NUDGES_ENABLED=0

# Bot simulation
# When BOT_SIMULATION_ENABLED is truthy the BotsModule auto-starts every
# IDLE/PAUSED BotProfile on app boot via BullMQ-scheduled BotActionJobs.
# Leave unset in production. See apps/api/docs/BOT_OPS.md for the full
# operations runbook.
BOT_SIMULATION_ENABLED=
# Optional cap — only auto-start the first N bots ordered by createdAt.
# Useful when staging has more bots than the demo needs.
BOT_SIMULATION_MAX_BOTS=
# When BOT_DEMO_MODE is truthy the scheduler bypasses persona-defined
# action intervals + active-hours and uses the BOT_DEMO_*_INTERVAL_MS
# values below instead. Intended for live demos and integration tests.
BOT_DEMO_MODE=
BOT_DEMO_MIN_INTERVAL_MS=10000
BOT_DEMO_MAX_INTERVAL_MS=60000
