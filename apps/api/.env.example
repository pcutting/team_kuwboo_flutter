# Kuwboo API — Local Development Environment
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000

# Logging (Pino)
# Levels: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kuwboo
DB_USER=kuwboo_admin
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRY=7d

# Twilio (phone OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Firebase (push notifications)
# On EC2 prod these come from AWS Secrets Manager (/kuwboo/firebase) when
# AWS_LOAD_SECRETS=1. See apps/api/src/bootstrap/aws-secrets.ts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AWS Secrets Manager bootstrap
# Set to "1" in environments where the process can assume an IAM role that
# permits secretsmanager:GetSecretValue on arn:aws:secretsmanager:eu-west-2:
# *:secret:/kuwboo/*. On EC2 (prod) this should be 1. In local dev leave
# empty and populate FIREBASE_* manually in .env.
AWS_LOAD_SECRETS=
AWS_REGION=eu-west-2

# Apple Sign In
# APPLE_BUNDLE_ID is the iOS App ID (e.g. com.kuwboo.app). Every Apple
# identity token and Server-to-Server notification MUST have aud equal
# to APPLE_BUNDLE_ID (or APPLE_SERVICE_ID when set).
# Required in production; AppleJwksService will fail closed if empty.
APPLE_BUNDLE_ID=com.kuwboo.app
# APPLE_SERVICE_ID is optional — set it to enable "Sign in with Apple"
# on the web (future kuwboo.com button). Leave blank for mobile-only.
APPLE_SERVICE_ID=
# Reserved for the future /auth/apple/token and /auth/apple/revoke
# endpoints which need a client secret signed with the .p8 private key.
# Not consumed by PR 2; provisioned together so the secret bundle is
# validated in one place.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# AWS (media storage)
AWS_REGION=eu-west-2
AWS_S3_BUCKET=kuwboo-media-dev
AWS_CLOUDFRONT_DOMAIN=

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# Profile-completeness nudges (D3a)
# When 1/true/yes, the nightly cron enumerates users whose
# profile_completeness_pct < 70 and enqueues one FCM nudge per eligible
# user (respecting the 7-day per-user cooldown). Leave at 0 in dev /
# staging to avoid spamming test devices.
NUDGES_ENABLED=0
