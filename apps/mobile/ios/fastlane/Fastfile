# Kuwboo iOS Fastfile
#
# Lanes:
#   fastlane beta    — Build and upload to TestFlight (CI + local)
#   fastlane build   — Just build the .ipa (no upload)
#   fastlane tests   — Run Flutter + unit tests
#
# Required environment variables (CI loads these from GitHub Secrets):
#   APP_STORE_CONNECT_API_KEY_ID       — e.g. "3B764CRX7S"
#   APP_STORE_CONNECT_API_ISSUER_ID    — UUID from App Store Connect
#   APP_STORE_CONNECT_API_KEY_CONTENT  — Full .p8 file contents (including header/footer)
#                                        OR base64-encoded with APP_STORE_CONNECT_API_KEY_IS_BASE64=true
#   KUWBOO_ENV                         — dev | staging | prod (default: prod for beta lane)
#
# Optional:
#   BUILD_NUMBER                       — Override build number (otherwise uses GitHub run number or timestamp)
#   MATCH_PASSWORD                     — Only if using fastlane match (not used by default)

default_platform(:ios)

MOBILE_ROOT = File.expand_path("../..", __dir__)
IOS_ROOT = File.expand_path("..", __dir__)
PROJECT_ROOT = File.expand_path("../../../..", __dir__)

platform :ios do
  before_all do
    # Ensure we're running from a known directory
    Dir.chdir(IOS_ROOT)
  end

  desc "Run Flutter tests"
  lane :tests do
    Dir.chdir(MOBILE_ROOT) do
      sh("flutter pub get")
      sh("flutter test")
    end
  end

  desc "Build iOS .ipa (no upload). Used for PR validation."
  lane :build do
    kuwboo_env = ENV["KUWBOO_ENV"] || "staging"
    build_number = resolve_build_number

    Dir.chdir(MOBILE_ROOT) do
      sh("flutter clean")
      sh("flutter pub get")
      sh("flutter build ios --release " \
         "--no-codesign " \
         "--build-number=#{build_number} " \
         "--dart-define=KUWBOO_ENV=#{kuwboo_env}")
    end

    UI.success("iOS build complete for env=#{kuwboo_env}, build=#{build_number}")
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    kuwboo_env = ENV["KUWBOO_ENV"] || "prod"
    build_number = resolve_build_number

    UI.message("Building Kuwboo for TestFlight: env=#{kuwboo_env}, build=#{build_number}")

    # Load App Store Connect API key from environment
    api_key = load_app_store_connect_api_key

    # Step 1: Flutter compiles Dart + produces an xcarchive with --no-codesign.
    #
    # Why --no-codesign: Flutter's built-in codesign preflight in
    # code_signing.dart uses a regex that only matches certificates whose
    # Common Name contains "Develop(ment|er)". Apple Distribution certs are
    # therefore invisible to it, even when xcodebuild can find them just
    # fine in the keychain. Passing --no-codesign sets CODE_SIGNING_ALLOWED=NO
    # in xcodebuild so Flutter's preflight is skipped entirely and the
    # archive is built unsigned. We then do the actual signing in step 2.
    Dir.chdir(MOBILE_ROOT) do
      sh("flutter clean")
      sh("flutter pub get")
      sh("cd ios && pod install --repo-update")
      sh("flutter -v build ipa --release --no-codesign " \
         "--build-number=#{build_number} " \
         "--dart-define=KUWBOO_ENV=#{kuwboo_env}")
    end

    # Step 2: Sign and export the unsigned xcarchive into a distributable
    # .ipa using xcodebuild directly. xcodebuild finds the Apple Distribution
    # cert in the keychain and the App Store provisioning profile in
    # ~/Library/MobileDevice/Provisioning Profiles/ (both installed by the
    # workflow before this lane runs). -allowProvisioningUpdates lets
    # xcodebuild use the App Store Connect API key for any cert/profile
    # refresh the team may need.
    archive_path = File.join(MOBILE_ROOT, "build", "ios", "archive", "Runner.xcarchive")
    export_dir = File.join(MOBILE_ROOT, "build", "ios", "ipa")
    export_plist = File.join(IOS_ROOT, "ExportOptions.plist")

    UI.user_error!("xcarchive not found at #{archive_path}") unless Dir.exist?(archive_path)
    UI.user_error!("ExportOptions.plist not found at #{export_plist}") unless File.exist?(export_plist)

    FileUtils.mkdir_p(export_dir)
    sh("xcodebuild -exportArchive " \
       "-archivePath '#{archive_path}' " \
       "-exportPath '#{export_dir}' " \
       "-exportOptionsPlist '#{export_plist}' " \
       "-allowProvisioningUpdates")

    # Locate the produced .ipa (xcodebuild names it from the product name,
    # typically Runner.ipa or kuwboo_mobile.ipa depending on PRODUCT_NAME).
    ipa_path = Dir.glob(File.join(export_dir, "*.ipa")).first
    UI.user_error!("No .ipa found in #{export_dir} after export") unless ipa_path && File.exist?(ipa_path)

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      changelog: generate_changelog,
      distribute_external: false,
    )

    UI.success("✅ Uploaded build #{build_number} to TestFlight")
  end

  # ------------------------------------------------------------------
  # Helpers
  # ------------------------------------------------------------------

  def load_app_store_connect_api_key
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_API_ISSUER_ID"]
    key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
    is_base64 = ENV["APP_STORE_CONNECT_API_KEY_IS_BASE64"] == "true"

    UI.user_error!("APP_STORE_CONNECT_API_KEY_ID not set") if key_id.nil? || key_id.empty?
    UI.user_error!("APP_STORE_CONNECT_API_ISSUER_ID not set") if issuer_id.nil? || issuer_id.empty?
    UI.user_error!("APP_STORE_CONNECT_API_KEY_CONTENT not set") if key_content.nil? || key_content.empty?

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: is_base64,
      in_house: false,
    )
  end

  def resolve_build_number
    explicit = ENV["BUILD_NUMBER"]
    return explicit.to_i if explicit && !explicit.empty?

    gh_run = ENV["GITHUB_RUN_NUMBER"]
    return gh_run.to_i if gh_run && !gh_run.empty?

    # Fallback: timestamp-based (yyMMddHHmm) so builds always increase
    Time.now.strftime("%y%m%d%H%M").to_i
  end

  def generate_changelog
    # Use git log since last tag, or fall back to last 10 commits
    Dir.chdir(PROJECT_ROOT) do
      last_tag = `git describe --tags --abbrev=0 2>/dev/null`.strip
      range = last_tag.empty? ? "HEAD~10..HEAD" : "#{last_tag}..HEAD"
      log = `git log --pretty=format:"- %s" #{range} 2>/dev/null`.strip
      log = `git log --pretty=format:"- %s" -n 10`.strip if log.empty?
      log.empty? ? "Internal build" : log
    end
  end
end
