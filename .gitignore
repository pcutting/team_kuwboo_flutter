# Flutter/Dart
.dart_tool/
.packages
build/
!apps/web/build/
apps/web/build/*
!apps/web/build/web/
*.iml
.idea/
.vscode/
# Broad *.lock block (originally added for melos .lock files and similar).
# Specific lock files we DO want tracked are re-included below.
*.lock
# Track Dart workspace lock file (reproducible pub resolution across devs + CI)
!**/pubspec.lock
# Track CocoaPods lock file (reproducible iOS native dependency versions)
!**/Podfile.lock

# Melos
.melos/

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example

# Coverage
coverage/
.flutter-plugins-dependencies
.dart_tool/
.vercel

# Node.js (apps/api, apps/admin, apps/slack-bridge, infrastructure/slack-runner)
apps/*/node_modules/
infrastructure/*/node_modules/
apps/api/dist/
*.tsbuildinfo
.claude/

# Playwright MCP session artefacts
.playwright-mcp/

# Apple signing keys — NEVER COMMIT
*.p8
AuthKey_*.p8
apps/mobile/ios/secrets/
/keys/
*.key
*.cer
*.p12
*.mobileprovision
*.certSigningRequest

# Fastlane runtime artifacts
apps/mobile/ios/fastlane/report.xml
apps/mobile/ios/fastlane/README.md
apps/mobile/ios/fastlane/test_output/
apps/mobile/ios/fastlane/screenshots/

# CocoaPods
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/ios/Flutter/Flutter.framework/
apps/mobile/ios/Flutter/Flutter.podspec

# iOS build artifacts
apps/mobile/ios/Runner/GeneratedPluginRegistrant.*
apps/mobile/ios/build/
apps/mobile/build/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies

# Android build artifacts
apps/mobile/android/.gradle/
apps/mobile/android/app/debug/
apps/mobile/android/app/profile/
apps/mobile/android/app/release/
apps/mobile/android/local.properties
apps/mobile/android/key.properties
apps/mobile/android/**/*.keystore
apps/mobile/android/**/*.jks

# Android signing + Play Store service account (keys/ is already globally
# gitignored; these patterns are belt-and-braces against material landing
# elsewhere in the tree)
*.jks
*.keystore
keys/kuwboo-play-ci.json
keys/kuwboo-upload.pem
keys/.android_keystore_password.txt
keys/.android_key_alias.txt

# Fastlane runtime artifacts (Android)
apps/mobile/android/fastlane/report.xml
apps/mobile/android/fastlane/README.md
apps/mobile/android/fastlane/test_output/
android/.kotlin/
